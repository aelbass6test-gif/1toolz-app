# Cloudflare SaaS Automation details for Custom Domains Integration
# To configure real automated, on-demand SSL for your SaaS customers' domains instantly via the Cloudflare API,
# provide your Cloudflare API token (with "Zone.Custom Hostnames" read/write access) and Zone ID below.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here
