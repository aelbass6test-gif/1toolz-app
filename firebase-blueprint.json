{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "joinDate": { "type": "string" },
        "stores": { "type": "array" },
        "sites": { "type": "array" }
      },
      "required": ["fullName", "phone", "password"]
    },
    "StoreData": {
      "title": "Store Data",
      "description": "Store configuration and summary data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "settings": { "type": "object" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "storeId": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "referenceNumber": { "type": "string" },
        "waybillNumber": { "type": "string" },
        "date": { "type": "string" },
        "shippingCompany": { "type": "string" },
        "shippingArea": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerPhone2": { "type": "string" },
        "customerAddress": { "type": "string" },
        "city": { "type": "string" },
        "governorate": { "type": "string" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "shippingFee": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "adminFee": { "type": "number" },
        "totalAmountOverride": { "type": "number" },
        "totalAmountOverrideReason": { "type": "string" },
        "includeInspectionFee": { "type": "boolean" },
        "isInsured": { "type": "boolean" },
        "inspectionFeePaidByCustomer": { "type": "boolean" },
        "collectionProcessed": { "type": "boolean" },
        "preparationStatus": { "type": "string" },
        "classification": { "type": "string" },
        "redeemedPoints": { "type": "number" },
        "pointsDiscount": { "type": "number" },
        "loyaltyPointsAwarded": { "type": "boolean" },
        "stockDeducted": { "type": "boolean" },
        "orderType": { "type": "string" },
        "shipmentType": { "type": "string" },
        "maintenanceCost": { "type": "number" },
        "maintenanceItemDescription": { "type": "string" },
        "maintenanceStatus": { "type": "string" },
        "warehouseId": { "type": "string" },
        "creditAmount": { "type": "number" },
        "advancePayment": { "type": "number" },
        "advancePaymentEmployeeId": { "type": "string" },
        "advancePaymentHistory": { "type": "array" },
        "advancePaymentPartnerId": { "type": "string" },
        "advancePaymentRecipientPhone": { "type": "string" },
        "advancePaymentSenderDetails": { "type": "string" },
        "advancePaymentTreasuryId": { "type": "string" },
        "createdBy": { "type": "string" },
        "source": { "type": "string" },
        "channel": { "type": "string" },
        "vatOnStandardShipping": { "type": "boolean" },
        "enableFlexShip": { "type": "boolean" },
        "flexShipFee": { "type": "number" },
        "flexShipCompanyFee": { "type": "number" },
        "flexShipFeePaidByCustomer": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "governorate": { "type": "string" },
        "city": { "type": "string" },
        "debtBalance": { "type": "number" },
        "debtHistory": { "type": "array" },
        "totalOrders": { "type": "number" },
        "totalSpent": { "type": "number" },
        "lastOrderDate": { "type": "string" }
      }
    },
    "CashHandover": {
      "title": "Cash Handover",
      "description": "Cash handover record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "toUserId": { "type": "string" },
        "toUserName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "orderId": { "type": "string" }
      }
    }
  },
