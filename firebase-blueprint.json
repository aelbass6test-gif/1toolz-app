{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "joinDate": { "type": "string" },
        "stores": { "type": "array" },
        "sites": { "type": "array" }
      },
      "required": ["fullName", "phone", "password"]
    },
    "StoreData": {
      "title": "Store Data",
      "description": "Store configuration and summary data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "settings": { "type": "object" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "storeId": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "status": { "type": "string" },
        "storeId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/stores_data/{storeId}": {
      "schema": "StoreData",
      "description": "Core store settings"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products list"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders list"
    },
    "/transactions/{id}": {
      "schema": "object",
      "description": "Financial transactions"
    },
    "/treasury_accounts/{id}": {
      "schema": "object",
      "description": "Treasury accounts"
    },
    "/treasury_transactions/{id}": {
      "schema": "object",
      "description": "Treasury transactions"
    },
    "/suppliers/{id}": {
      "schema": "object",
      "description": "Suppliers"
    },
    "/supply_orders/{id}": {
      "schema": "object",
      "description": "Supply orders"
    },
    "/reviews/{id}": {
      "schema": "object",
      "description": "Product reviews"
    },
    "/abandoned_carts/{id}": {
      "schema": "object",
      "description": "Abandoned carts"
    },
    "/activity_logs/{id}": {
      "schema": "object",
      "description": "Activity logs"
    },
    "/employees/{id}": {
      "schema": "object",
      "description": "Employees"
    },
    "/discount_codes/{id}": {
      "schema": "object",
      "description": "Discount codes"
    },
    "/collections/{id}": {
      "schema": "object",
      "description": "Product collections"
    },
    "/custom_pages/{id}": {
      "schema": "object",
      "description": "Custom pages"
    },
    "/payment_methods/{id}": {
